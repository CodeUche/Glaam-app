<?xml version="1.0" encoding="utf-8"?>
<!--
    Allows plain HTTP connections to local network addresses.
    Required for connecting to the GlamConnect Windows server over WiFi.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
